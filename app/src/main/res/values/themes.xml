<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BikeNav" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">#00E5A0</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorPrimaryContainer">#00553A</item>
        <item name="colorOnPrimaryContainer">#80FFD0</item>

        <item name="colorSecondary">#A0C0B0</item>
        <item name="colorOnSecondary">#003020</item>
        <item name="colorSecondaryContainer">#004A30</item>
        <item name="colorOnSecondaryContainer">#BCECE0</item>

        <item name="android:colorBackground">#0D0D0F</item>
        <item name="colorOnBackground">#E0E0E0</item>

        <item name="colorSurface">#0D0D0F</item>
        <item name="colorOnSurface">#E0E0E0</item>
        <item name="colorSurfaceVariant">#25252A</item>
        <item name="colorOnSurfaceVariant">#A0A0A0</item>
        <item name="colorSurfaceContainerLow">#151518</item>
        <item name="colorSurfaceContainer">#1A1A1E</item>
        <item name="colorSurfaceContainerHigh">#202025</item>
        <item name="colorSurfaceContainerHighest">#2A2A30</item>

        <item name="colorOutline">#50505A</item>
        <item name="colorOutlineVariant">#303038</item>

        <item name="colorError">#FF5555</item>
        <item name="colorOnError">#000000</item>

        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>

        <item name="materialAlertDialogTheme">@style/ThemeOverlay.BikeNav.Dialog</item>
    </style>

    <style name="Theme.BikeNav.Splash" parent="Theme.BikeNav">
        <item name="android:windowBackground">#0D0D0F</item>
    </style>

    <style name="ThemeOverlay.BikeNav.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="buttonBarPositiveButtonStyle">@style/Widget.BikeNav.Dialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.BikeNav.Dialog.Button.Muted</item>
    </style>

    <style name="Widget.BikeNav.Dialog.Button" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <style name="Widget.BikeNav.Dialog.Button.Muted" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="Widget.BikeNav.Button.Pill.Filled" parent="Widget.Material3.Button">
        <item name="cornerRadius">100dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="rippleColor">#40FFFFFF</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.BikeNav.Button.Pill.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">100dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">?attr/colorPrimary</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:minHeight">44dp</item>
    </style>

    <style name="Widget.BikeNav.Button.Pill.Outlined.Accent" parent="Widget.BikeNav.Button.Pill.Outlined">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="strokeColor">?attr/colorPrimary</item>
    </style>
</resources>
