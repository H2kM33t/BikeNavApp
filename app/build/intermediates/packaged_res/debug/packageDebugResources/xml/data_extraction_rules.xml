<?xml version="1.0" encoding="utf-8"?>
<!--
  Explicitly excludes ALL app data from cloud backup and adb backup.
  This app stores the paired ESP32's BLE MAC address in SharedPreferences;
  there's no reason for that to leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
